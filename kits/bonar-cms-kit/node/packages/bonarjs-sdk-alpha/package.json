{
  "name": "@botanarede/bonarjs-sdk-alpha",
  "version": "0.1.0",
  "description": "Provider-agnostic TypeScript SDK that unifies the bonarjs-sdk client and bonar-cms-api backend into a single npm package.",
  "author": "botanarede",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./firebase": {
      "types": "./dist/providers/firebase/index.d.ts",
      "import": "./dist/providers/firebase/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "firebase": ">=10",
    "firebase-admin": ">=12",
    "next": ">=14",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "firebase": {
      "optional": true
    },
    "firebase-admin": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "firebase": "^12.12.1",
    "firebase-admin": "^12.7.0",
    "msw": "^2.6.0",
    "next": "^16.2.3",
    "react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
