# Node.js dependencies (resolved by pnpm install)
node_modules/
packages/*/node_modules/

# Build output (regenerated by pnpm run build:schema)
packages/*/dist/

# Environment files with real credentials
.env.local

# Tenant images (large, client-specific)
apps/creator-studio/public/images/
apps/creator-studio/public/icons/

# Tenant configs (except template and demo)
tenants/*.json
!tenants/template.json
!tenants/demo.json
tenants-assets/*
!tenants-assets/demo/
