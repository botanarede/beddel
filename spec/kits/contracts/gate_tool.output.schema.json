{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "gate_tool output",
  "description": "Shared output schema for gate tools. Same structure as shell_exec output.",
  "type": "object",
  "properties": {
    "exit_code": {
      "type": "integer",
      "description": "Process exit code."
    },
    "stdout": {
      "type": "string",
      "description": "Standard output."
    },
    "stderr": {
      "type": "string",
      "description": "Standard error."
    },
    "timed_out": {
      "type": "boolean",
      "description": "Whether the process timed out."
    },
    "truncated": {
      "type": "boolean",
      "description": "Whether output was truncated."
    }
  },
  "required": [
    "exit_code",
    "stdout",
    "stderr",
    "timed_out",
    "truncated"
  ],
  "additionalProperties": false
}
