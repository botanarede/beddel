{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "file_write output",
  "description": "Output structure for the file_write builtin tool.",
  "type": "object",
  "properties": {
    "written": {
      "type": "boolean",
      "description": "Whether the write succeeded."
    },
    "path": {
      "type": "string",
      "description": "The path that was written to."
    }
  },
  "required": [
    "written",
    "path"
  ],
  "additionalProperties": false
}
