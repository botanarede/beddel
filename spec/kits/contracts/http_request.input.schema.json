{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "http_request input",
  "description": "Input parameters for the http_request builtin tool.",
  "type": "object",
  "properties": {
    "method": {
      "type": "string",
      "description": "HTTP method (GET, POST, PUT, DELETE, etc.)."
    },
    "url": {
      "type": "string",
      "description": "Target URL."
    },
    "headers": {
      "type": [
        "object",
        "null"
      ],
      "default": null,
      "description": "Optional request headers.",
      "additionalProperties": {
        "type": "string"
      }
    },
    "body": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional request body. If a dict, it is JSON-serialized."
    }
  },
  "required": [
    "method",
    "url"
  ],
  "additionalProperties": false
}
